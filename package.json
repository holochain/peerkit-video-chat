{
  "name": "peerkit-video-chat",
  "version": "0.0.0",
  "description": "Showcase video chat application built on PeerKit",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "tsc --build",
    "build:clean": "tsc --build --clean",
    "typecheck": "tsc --build",
    "dev:desktop": "npm run dev -w @peerkit-video-chat/desktop",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.5"
  }
}
